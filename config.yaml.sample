# Configuration file for backup_remote_files
# All parameters can be overridden with environment variables prefixed with "BRF_"
# Environment variable naming:
#   - Flat keys (camelCase): convert to UPPERCASE without underscores
#     Example: retryInterval -> BRF_RETRYINTERVAL, metricsPrefix -> BRF_METRICSPREFIX
#   - Nested keys (dots): use UPPERCASE with underscores for nesting
#     Example: logging.level -> BRF_LOGGING_LEVEL

backups:
  someid:
    url: https://some.url/data
    username: ""
    password: ""
    outputFile: "outputfile"

interval: "2h"
retryInterval: "10m"
metricsPrefix: "brf"

logging:
  level: INFO          # Log level (DEBUG, INFO, WARN, ERROR)
  filename: backup.log # or "stdout" or "stderr"
  maxSize: 10          # Megabytes before rotation
  maxBackups: 5        # Number of old log files to keep
  maxAge: 7            # Days to keep old log files
  compress: true       # Compress rotated files
  json: false          # Log in JSON
